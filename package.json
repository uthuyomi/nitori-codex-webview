{
  "name": "nitori-codex-webview",
  "displayName": "Nitori Codex Webview",
  "description": "A lightweight Webview chat UI that talks to the local Codex app-server, with a customizable avatar.",
  "version": "0.0.35",
  "publisher": "kaisei-yasuzaki",
  "engines": {
    "vscode": "^1.109.0"
  },
  "icon": "media/nitori.png",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/uthuyomi/nitori-codex-webview.git"
  },
  "homepage": "https://github.com/uthuyomi/nitori-codex-webview",
  "bugs": {
    "url": "https://github.com/uthuyomi/nitori-codex-webview/issues"
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "package": "npm run build",
    "vscode:prepublish": "npm run build"
  },
  "activationEvents": [
    "onCommand:nitoriCodex.open",
    "onView:nitoriCodex.sidebarView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nitoriCodex.open",
        "title": "Nitori: Open Codex Webview"
      }
    ],
    "configuration": {
      "title": "Nitori Codex",
      "properties": {
        "nitoriCodex.codexPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to the Codex CLI executable. If not set, the extension tries to auto-detect it, otherwise falls back to 'codex' in PATH."
        },
        "nitoriCodex.verboseEvents": {
          "type": "boolean",
          "default": false,
          "description": "Show verbose internal events (tool calls, web search results, unknown items) in the chat as system messages. Can be noisy and slow."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nitoriCodexViewContainer",
          "title": "Nitori",
          "icon": "resources/nitori.svg"
        }
      ]
    },
    "views": {
      "nitoriCodexViewContainer": [
        {
          "id": "nitoriCodex.sidebarView",
          "type": "webview",
          "name": "Nitori Codex"
        }
      ]
    }
  },
  "keywords": ["codex", "chat", "webview"],
  "author": "kaisei-yasuzaki",
  "license": "MIT",
  "dependencies": {
    "@shikijs/transformers": "^3.12.2",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "markdown-it": "^14.1.0",
    "shiki": "^3.12.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.109.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
